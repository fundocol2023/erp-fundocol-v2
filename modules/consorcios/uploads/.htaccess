Options -Indexes

<IfModule mod_authz_core.c>
    <FilesMatch "(?i)\.(?:php[0-9]?|phtml|phar|cgi|pl|py|sh)$">
        Require all denied
    </FilesMatch>
</IfModule>

<IfModule !mod_authz_core.c>
    <FilesMatch "(?i)\.(?:php[0-9]?|phtml|phar|cgi|pl|py|sh)$">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
</IfModule>
