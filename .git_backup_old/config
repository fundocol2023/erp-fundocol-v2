[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
[remote "origin"]
	url = https://github.com/fundocol2023/erp-fundocol.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
[pull]
	rebase = false
[branch "staging"]
	vscode-merge-base = origin/main
	remote = origin
	merge = refs/heads/staging
[branch "develop"]
	vscode-merge-base = origin/main
	remote = origin
	merge = refs/heads/develop
